# Frontend Environment Variables
# Copy this file to .env.local for local development
# For production, set these in Vercel dashboard (Settings > Environment Variables)

# API Base URL - Point to your backend
# Local development: http://localhost:8000/api/core
# Production: https://api.zainussunnaacademy.com/api
REACT_APP_API_URL=http://localhost:8000/api/core

